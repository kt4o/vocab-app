VITE_API_BASE_URL=https://api.yourdomain.com
VITE_APP_ENV=production
VITE_STYLE_VARIANT_DEFAULT=default
# Primary analytics (recommended for Google Ads integration)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Temporary fallback analytics (used only when GA ID is not set)
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Backend only. Do not expose this as a VITE_ variable.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_TRANSLATION_MODEL=gpt-5-mini
# Used for English definitions, English-to-Japanese, and Japanese-to-English vocabulary lookups.
OPENAI_TRANSLATION_ENABLED=true
