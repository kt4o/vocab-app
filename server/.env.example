PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/my_vocab_app
PGSSLMODE=disable

# CORS (optional, comma-separated for multiple origins)
# CORS_ORIGIN=http://localhost:5173
# CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
# ALLOW_LOCALHOST_IN_PRODUCTION=true

# Auth session cookie
AUTH_COOKIE_NAME=vocab_session
# AUTH_COOKIE_SAMESITE=lax
# Use "none" if frontend and API are on different sites (requires HTTPS).
# AUTH_COOKIE_SECURE=true

# Country access controls (optional, ISO 3166-1 alpha-2 codes)
# Uses edge/proxy headers like CF-IPCountry, x-vercel-ip-country, cloudfront-viewer-country.
# ALLOWED_COUNTRIES=US,CA,AU
# BLOCKED_COUNTRIES=CU,IR,KP,SY

# Write rate limit (optional)
WRITE_RATE_LIMIT_WINDOW_MS=900000
WRITE_RATE_LIMIT_MAX_ATTEMPTS=180

# Username moderation (optional)
# Add extra blocked terms (comma/newline separated), e.g. badword1,badword2
USERNAME_BLOCKLIST_EXTRA=

# Email (SMTP)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=Vocalibry <no-reply@yourdomain.com>

# Stripe billing
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_TRIAL_DAYS=30
APP_BASE_URL=http://localhost:5173
# ALLOW_UNSAFE_APP_BASE_URL_IN_PRODUCTION=true
LEGAL_VERSION=2026-03-14
