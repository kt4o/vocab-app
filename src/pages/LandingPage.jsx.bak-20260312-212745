export function LandingPage() {
  const masteryFlowRef = useRef(null);
  const [isMasteryFlowVisible, setIsMasteryFlowVisible] = useState(false);

  useEffect(() => {
    const node = masteryFlowRef.current;
    if (!node) return undefined;

    const observer = new IntersectionObserver(
      (entries) => {
        const entry = entries[0];
        if (entry?.isIntersecting) {
          setIsMasteryFlowVisible(true);
          observer.disconnect();
        }
      },
      { threshold: 0.28 }
    );

    observer.observe(node);
    return () => observer.disconnect();
  }, []);

  return (
    <div className="publicPage publicLanding">
      <header className="publicHeader">
        <a className="publicLogo" href="/">
          Vocalibry
