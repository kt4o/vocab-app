            <p className="heroCopy">
              Learn new words, review by chapter, and reinforce memory with flashcards and quizzes in one
              clean workspace.
            </p>
            <div className="heroActions">
              <a className="publicPrimaryBtn" href="/login">
                Log in
              </a>
              <a className="publicSecondaryBtn" href="/register">
                Register
              </a>
            </div>
            <div className="heroMiniHighlights" aria-label="Product highlights">
              <span>Chapter-based workflow</span>
              <span>Flashcards and quizzes</span>
              <span>Progress tracking</span>
            </div>
          </div>
          <div className="heroVisual">
            <img
              className="heroScreenshot"
              src="/landing/dashboard.png"
              alt="Vocalibry dashboard screenshot"
            />
          </div>
        </section>

        <section className="landingStats" aria-label="Product summary">
          {HIGHLIGHT_STATS.map((item) => (
            <article key={item.label} className="landingStatCard">
              <span className="landingInlineIcon">
                <LandingIcon name={item.icon} />
              </span>
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </article>
          ))}
        </section>

        <section className="landingImageShowcase" aria-label="Visual highlights">
          <div className="landingSectionHead">
            <p className="landingSectionEyebrow">Real product feel</p>
            <h2>Built around the exact workflows you use every day</h2>
          </div>
          <div className="landingScreenGrid">
            {APP_SCREEN_PREVIEWS.map((screen) => (
              <article key={screen.key} className={`landingScreenCard ${screen.accentClass}`}>
                <div className="landingScreenTop">
                  <span className="landingScreenTag">{screen.label}</span>
                  <span className="landingScreenDots" aria-hidden="true">
                    <i />
                    <i />
                    <i />
                  </span>
                </div>
                <p className="landingScreenTitle">{screen.title}</p>
                <img
                  className="landingScreenImage"
                  src={screen.imageSrc}
                  alt={screen.imageAlt}
                  loading="lazy"
                />
                <ul className="landingScreenPoints">
                  {screen.points.map((point) => (
                    <li key={point}>{point}</li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <section
