                  <div className="masteryFlowTop">
                    <span className="masteryFlowIndex">{String(index + 1).padStart(2, "0")}</span>
                    <span className="masteryFlowIcon">
                      <LandingIcon name={step.icon} />
                    </span>
                  </div>
                  <p className="masteryFlowStage">{step.stage}</p>
                  <h3>{step.title}</h3>
                  <p>{step.detail}</p>
                  <div className="masteryFlowMeter" aria-hidden="true">
                    <span style={{ "--meter-target": `${step.progress}%` }} />
                  </div>
                </li>
              ))}
